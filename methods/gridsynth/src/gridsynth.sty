% ---------------------------------------------------
% Macros for computing with PGF.

% Essential commands for formulas and assertions.
\usepackage{pgf}
{\makeatletter\global\let\error\@latex@error}

% Precision = 3 digits.
\pgfkeys{/pgf/number format/.cd,fixed,precision=3}

% Assert some numerical statement. Throw an 
% error if the statement is not true.
\newcommand{\assert}[1]{%
\pgfmathparse{#1}%
  \ifnum1=\pgfmathresult
  \else\error
    {Assertion failed: #1, \pgfmathresult}
  \fi}

% Print a computed expression.
\newcommand{\formula}[1]{
\pgfmathparse{#1}
\pgfmathprintnumber{\pgfmathresult}}

% Example defined formulas.
\def\roundone#1{round(10*(#1))/10}
\def\roundthree#1{round(1000*(#1))/1000}

% Exponentiation seems to be broken in PGF. 
% E.g. without the modification below,
% \formula{4^(-0.5)} will print 2 instead 
% of 0.5.
%
% The redefinition below appears to fix the 
% problem. It was taken from:
%
% http://tex.stackexchange.com/questions/31775/is-plotting-exponential-graphs-a-known-source-of-bugs-in-tikz
\makeatletter
% undefine old exp function
\let\pgfmath@function@exp\relax 
\pgfmathdeclarefunction{exp}{1}{%   
  \begingroup
    \pgfmath@xc=#1pt\relax
    \pgfmath@yc=#1pt\relax
    \ifdim\pgfmath@xc<-9pt
      \pgfmath@x=1sp\relax
    \else
      \ifdim\pgfmath@xc<0pt
        \pgfmath@xc=-\pgfmath@xc
      \fi
      \pgfmath@x=1pt\relax
      \pgfmath@xa=1pt\relax
      \pgfmath@xb=\pgfmath@x
      \pgfmathloop%
        \divide\pgfmath@xa by\pgfmathcounter
        \pgfmath@xa=\pgfmath@tonumber\pgfmath@xc\pgfmath@xa%
        \advance\pgfmath@x by\pgfmath@xa
      \ifdim\pgfmath@x=\pgfmath@xb
      \else
        \pgfmath@xb=\pgfmath@x
      \repeatpgfmathloop%
      \ifdim\pgfmath@yc<0pt
        \pgfmathreciprocal@{\pgfmath@tonumber\pgfmath@x}%
        \pgfmath@x=\pgfmathresult pt\relax
      \fi
    \fi
    \pgfmath@returnone\pgfmath@x%
  \endgroup
}
\makeatother

% ---------------------------------------------------
% Parametrization.

% The R, A, B and K Lemmas are parametric. The global
% parameters are the desired uprightness and the step. 
% The Lemma-specific parameter is a bound defining a 
% region of the logarithmic plane in which the Lemma 
% holds. The values of these bounds are entered below. 
% If the provided values satisfy the conditions 
% required for the proofs to be correct, then the 
% document will build. Otherwise, Latex will throw an 
% error message specifying which condition failed.
%
% To find the assertions used in this document, search 
% for "Check!!!". Definitions and parameters follow.

% Lambda.
\def\l{((sqrt 2) + 1)}

% Hyperbolic sine.
\def\sinhl#1{((pow(\l, (#1)) - pow(\l, neg (#1)))/2)}

% Hyperbolic cosine.
\def\coshl#1{((pow(\l, (#1)) + pow(\l, neg (#1)))/2)}

% Log in base lambda.
\def\logl#1{(ln(#1) / ln(\l))}

% A helper function for Lemma K.
\def\kone#1{(((sqrt 2) - (\coshl {#1}))^2)}

% Uprightness.
\def\M{(1/\oneoverM)}
\def\oneoverM{ceil(1/(pi / (4* (sqrt (\P +1)))))}

% Skew-bound.
\def\P{15}

% Step.
\def\Qstep{0.9}

% R-bound.
\def\r{0.8}

% A-bound.
\def\a{(-0.3)}

% A-bound-1. For some reason, PGF will complain 
% if I ask it to compute, e.g.,
% \formula{\kone (\a -1)} but gladly accepts 
% \formula{\kone \aa}.
\def\aa{(\a -1)}

% -R-bound+1. As above.
\def\rr{(-\r+1)}

% B-bound.
\def\b{0.2}
