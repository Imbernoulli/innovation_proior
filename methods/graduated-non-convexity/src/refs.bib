@article{Marks10pami,
  Author = {T.K. Marks and J.R. Hershey and J.R. Movellan},
  C-Richard = {This paper discusses a space of problems resulting from jointly from images inferring object pose, texture, and deformation, in the context of tracking. Template tracking and optical flow are special cases of this model. The relationship of this work to our optical flow work is that both attempt to infer the state of the world directly from dense image measurements, using generative image models. In our case though, we are primarily focusing on structure from image velocity, whereas they include texture and appearance. We also explicitly model geometry, using models of trees as cylinders.},
