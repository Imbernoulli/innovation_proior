  Journal = {Annals of Mathematics and Artificial Intelligence},
  Number = {1-4},
  Pages = {7-40},
  R-Burgard05Tro = {focus on the problem of reducing the odometry error during exploration. They separate the environment into stripes that are explored successively by the robot team. Whenever one robot moves, the other robots are kept stationary and observe the moving robot, a strategy similar to the presented by Kurazume and Shigemi [Kurazume94icra]. Whereas this approach can signicantly reduce the odometry error during the exploration process, it is not designed to distribute the robots over the environment. Rather, the robots are forced to stay close to each other in order to remain in the visibility range.e},
  Title = {Multi-Robot Collaboration for Robust Exploration},
  Volume = 31,
  Year = 2001}

