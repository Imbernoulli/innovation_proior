@article{Wolbers08natneuro,
  Author = {T. Wolbers and M. Hegarty and C. B\"uchel and J. Loomis},
  C-Richard = {This is a psychology/neuroscience study on how the human brain updates the positions of objects as the observer moves through space. The study suggests that the brain uses optical flow to do this updating, using an egocentric map. (However, other studies suggest that humans use allocentric maps to remember the positions of objects for longer periods of time). This study also suggests that some brain regions only update object positions when the updated positions are needed, in this case for pointing at them. (This would be evidence of an allocentric map - the object locations are not actually updated during movement if they are not observed - their computed egocentric positions can then be computed as needed from the allocentric map).},
  Journal = {Nature Neuroscience},
  Number = 10,
  Pages = {1223-1230},
  Publisher = {Nature Publishing Group},
  Title = {Spatial updating: how the brain keeps track of changing object locations during observer motion},
  Volume = 11,
  Year = 2008}

