@inproceedings{Zitnick05iccv,
  Author = {C. Zitnick and N. Jojic and S. Kang},
  Booktitle = ICCV,
  C-Richard = {This paper deals with jointly estimating optical flow and image segmentation. They model the optical flow in each image segment as affine, and include image similarity terms for the purpose of segmentation. This is interesting because they use multiple "physical" models (the affine flow models) to explain parts of the image, jointly inferring which model instantiations explain which parts of the image. They are leveraging top-down knowledge of the types of flow patterns that are observed, and what image properties (i.e. appearance similarity) tend to indicate that an image region is contiguous. To use our language, the segmentation acts as data association, determining which image regions are explained by each instantiation of an affine flow model. In turn, the affine flow model is a physical model, that results from the assumption of objects moving rigidly in the scene, or motion of the camera.},
  Pages = {1308--1315},
  Title = {Consistent Segmentation for Optical Flow Estimation},
  Year = 2005}

