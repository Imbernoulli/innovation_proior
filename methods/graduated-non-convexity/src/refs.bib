@article{Nadel04neuropsych,
  Abstract = {Themes emerging from the collection of articles in
              the Special Section on Long-Term Spatial Memory
              include the notion of multiple spatial systems, the
              relation between spatial representations and
              episodic memory, the role of context, and the neural
              systems involved in space. The authors conclude that
              distinguishing between egocentric and allocentric
              spatial systems makes sense of both behavioral and
              neurobiological data. The special role of the
              hippocampal system in allocentric space, and as a
              consequence, in context, suggests how a spatial
              system might end up central to the ability to
              remember episodes.},
  Author = {Nadel, Lynn and Hardt, Oliver},
  C-Richard = {A review of literature on spatial representation. Says that egocentric and allocentric representations are separate and distinct systems in the brain. Also that the hippocampus may be involved in linking episodic memory with spatial memory.},
  Journal = {Neuropsychology},
  Month = {Jul},
  Number = 3,
  Pages = {473--476},
  Title = {The spatial brain},
  Volume = 18,
  Year = 2004}

@article{Nadel91hippocampus,
  Author = {Lynn Nadel},
  C-Dellaert = {Looking back on seminal book, a bit of a rant for insiders, not so useful.},
  Fullauthor = {L. Nadel},
  Journal = {Hippocampus},
  Month = {July},
  Number = 3,
  Pages = {221--229},
  Quotes = {I will concentrate on three major issues. First, I will discuss at some length the fact that our theory was about a spatial memory system, not simply a ?patial?system. Second, I will discuss our assumption that the spatial memory system we allocated to the hippocampus was but one of many spatial systems, and that the role of these various systems can best be understood if one takes into consideration an animal? behavior in its natural habitat. Third, I will briefly discuss our view that in the human hippocampus, at least in the left hemisphere, the mapping system represents something more abstract than physical space.},
  Title = {The Hippocampus and Space Revisited},
  Volume = 1,
  Year = 1991}

