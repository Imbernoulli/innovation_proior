@inproceedings{Konolige03rur,
  Abstract = {A set of robots mapping an area can potentially
              combine their information to produce a distributed
              map more efficiently than a single robot alone. We
              describe a general framework for distributed map
              building in the presence of uncertain communication,
              as well as an on-line, distributed algorithm that
              builds maps. The algorithms depend on the additive
              property of constraints in the Lu-Milios mapping
              technique. We show the results of large-scale
              (>100m2) indoor maps built using information from a
              set of mapping robots.},
  Address = {Acapulco, Mexico},
  Author = {K. Konolige and J. Gutmann and B. Limketkai},
  Booktitle = {Proc. IJCAI Workshop on Reasoning with Uncertainty in Robotics (RUR 2003)},
  Pages = {15~22},
  Title = {Distributed map-making},
  Year = 2003}

@inproceedings{Konolige04aaai,
  Abstract = {Current mapping algorithms using Consistent Pose
              Estimation (CPE) algorithms can successfully map
              areas of 104 square meters, using thousands of
              poses. However, the computation to construct the map
              grows as O(n log n), so larger maps get increasingly
              difficult to build. We present an abstraction method
              for postponing the growth in computation.  This
              method solves a much smaller problem in the space of
              the connection graph of the map.},
  Author = {K. Konolige},
  Crossref = {_AAAI04},
  Title = {Large-scale map-making}}

